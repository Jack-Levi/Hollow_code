texto[0] = "No funciono... El proyecto Hollow fallo y el centro de la tierra se convirtio en un agujero negro.";
texto[1] = "Los mounstros se liberaron...Ya no hay nada que podamos hacer.";
texto[2] = "En la siguiente sala nos espera el final, de todas formas moriremos por el agujero negro.";

